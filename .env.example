# Grok2API environment example
#
# 用法：
# 1. 复制为 .env 后按需修改
# 2. 启动期 / 部署期变量放这里
# 3. 常规运行时配置优先改 ${DATA_DIR}/config.toml


# ==================== 基础运行 ====================
TZ=Asia/Shanghai
LOG_LEVEL=INFO
# 写入本地文件日志
LOG_FILE_ENABLED=true
# 账号目录增量同步间隔（秒）
ACCOUNT_SYNC_INTERVAL=30


# ==================== Web 服务 / Docker Compose ====================
# Go binary listens on HOST:PORT.
HOST=0.0.0.0
PORT=8000

# Legacy Python/Granian names are still accepted by Docker Compose fallbacks.
# Keep them only while older compose files or deployment templates still refer to them.
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# SERVER_WORKERS is deprecated in the Go runtime and has no effect.
# SERVER_WORKERS=1

# Docker Compose 宿主机映射端口
HOST_PORT=8000


# ==================== 账号存储（启动期） ====================
# 可选：local | redis | mysql | postgresql
ACCOUNT_STORAGE=local

# redis: Redis DSN（ACCOUNT_STORAGE=redis 时必填）
# ACCOUNT_REDIS_URL=redis://:password@host:6379/0

# Redis runtime（可选）：用于后台任务快照、scheduler leader 锁等运行时协调
# 留空时使用本地进程内状态；若已配置 ACCOUNT_REDIS_URL，可直接复用同一个 Redis
# RUNTIME_REDIS_URL=redis://:password@host:6379/0
# RUNTIME_TASK_TTL_S=300
# RUNTIME_REDIS_LOCK_TTL_MS=300000

# mysql: Go DSN 或兼容的 mysql:// / mysql+aiomysql:// URL
# ACCOUNT_MYSQL_URL=user:password@tcp(127.0.0.1:3306)/grok2api?parseTime=true
# ACCOUNT_MYSQL_URL=mysql://user:password@127.0.0.1:3306/grok2api

# postgresql: Go/libpq URL；兼容 postgresql+asyncpg:// 前缀
# ACCOUNT_POSTGRESQL_URL=postgres://user:password@127.0.0.1:5432/grok2api?sslmode=disable
# ACCOUNT_POSTGRESQL_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/grok2api

# SQL 连接池（mysql / postgresql 模式，以下均为默认值，无需改动即可生效）
# ACCOUNT_SQL_POOL_SIZE=5
# ACCOUNT_SQL_MAX_OVERFLOW=10
# ACCOUNT_SQL_POOL_TIMEOUT=30
# ACCOUNT_SQL_POOL_RECYCLE=1800


# ==================== 可选：本地数据 / 日志目录 ====================
DATA_DIR=./data
LOG_DIR=./logs
